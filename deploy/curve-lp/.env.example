# Environment variables for Curve LP Solver deployment
#
# INSTRUCTIONS:
# 1. Copy this file to .env: cp .env.example .env
# 2. Fill in your actual values
# 3. NEVER commit .env to git
#
# QUOTING:
# deploy.sh sources this file with `set -a; source .env; set +a`. That means
# shell-special characters in values are interpreted unless quoted. Wrap any
# value containing `?`, `&`, `=`, `#`, `$`, `*`, `;`, `|`, `(`, `)`, `<`, `>`,
# or spaces in DOUBLE quotes — typical for RPC URLs with query-string keys
# (`?key=...&foo=bar`). When in doubt, quote.
#
#   NODE_URL="https://rpc.example.com/v1?api_key=abc&chain=eth"   # safe
#   NODE_URL=https://rpc.example.com/v1?api_key=abc&chain=eth     # broken:
#       # `&chain=eth` runs as a background command, NODE_URL silently ends
#       # at the `?`, and the deploy fails with "missing NODE_URL".
#
# For production on AWS, use:
# - AWS Secrets Manager, or
# - SSM Parameter Store, or
# - ECS task definition secrets

# Ethereum mainnet RPC endpoint (used by both prod and staging mainnet containers).
NODE_URL="https://eth-mainnet.g.alchemy.com/v2/YOUR_API_KEY_HERE"

# Arbitrum One RPC endpoint.
NODE_URL_ARBITRUM="https://arb-mainnet.g.alchemy.com/v2/YOUR_API_KEY_HERE"

# Gnosis Chain RPC endpoint.
NODE_URL_GNOSIS="https://gnosis-mainnet.g.alchemy.com/v2/YOUR_API_KEY_HERE"

# Domain for SSL certificate
DOMAIN=solver.momotaro.xyz

# Email for Let's Encrypt notifications
SSL_EMAIL=admin@momotaro.xyz

# Monitor UI at /monitor/ (optional). Set BOTH to enable the Basic-auth
# protected monitor page; omit both to disable. Password can contain shell
# metacharacters — quote it.
MONITOR_USER="ops"
MONITOR_PASSWORD="change-me"

# Telegram monitoring (optional)
TG_BOT_TOKEN=your-bot-token-from-botfather
TG_CHAT_ID=-1003703653353
TG_STATS_THREAD=        # General topic (leave empty for default)
TG_TRADES_THREAD=3      # Wins topic thread ID
